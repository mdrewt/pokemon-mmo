{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    // NOTE: exactOptionalPropertyTypes is disabled because the generated SpacetimeDB 2.6
    // TS bindings (frontend/src/module_bindings/, gitignored, do-not-edit) emit schema
    // types that are not assignable under that flag. All hand-written frontend code
    // typechecks cleanly with it on; only the generated bindings need it off.
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
