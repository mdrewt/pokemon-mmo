# ── Rust ──────────────────────────────────────────────
/target
**/target
# Keep Cargo.lock committed for the app crates (client-wasm, server-module)
# — it pins the exact build. Do NOT ignore it.

# ── WASM build output ─────────────────────────────────
# Generated by wasm-pack / the WASM toolchain; rebuilt from source.
client-wasm/pkg/
pkg/
**/pkg/
*.wasm

# ── SpacetimeDB generated client bindings ─────────────
# Derived from the schema — regenerate with `spacetime generate`. Ignored on purpose
# (they change every schema edit; `spacetime dev` regenerates them automatically).
frontend/src/module_bindings/
**/module_bindings/

# ── Frontend / bundler ────────────────────────────────
node_modules/
dist/
.vite/
*.tsbuildinfo

# ── Code knowledge graph index (codebase-memory-mcp) ──
# Derived index — never commit. Confirm the actual dir/config names on first setup
# (the tool writes to agent config + an index dir); add anything it generates here.
.codebase-memory/
.codebase-memory-mcp/
# (kept for reference if you ever switch tools)
.codegraph/
.gitnexus/
.code-graph/

# ── Secrets & env ─────────────────────────────────────
.env
.env.*
!.env.example

# ── OS / editor ───────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp

# Local Claude Code state (keep shared CLAUDE.md and skills tracked;
# ignore only personal/local settings).
.claude/settings.local.json
# MCP server config contains absolute paths — machine-specific, not shareable.
# Claude Code VS Code extension reads this from the project root (not .claude/).
.mcp.json

# Skills installed via `npx skills add` — derived, reinstall from CLAUDE.md.
.agents/
# npx artifacts created by `npx skills add` at project root — not project files.
biome.json
/package.json
/package-lock.json