# ── Rust ──────────────────────────────────────────────
/target
**/target
# Keep Cargo.lock committed for the app crates (client-wasm, server-module)
# — it pins the exact build. Do NOT ignore it.

# ── WASM build output ─────────────────────────────────
# Generated by wasm-pack / the WASM toolchain; rebuilt from source.
client-wasm/pkg/
pkg/
**/pkg/
*.wasm

# ── SpacetimeDB generated client bindings ─────────────
# COMMITTED (not ignored): the frontend tsc/eslint/vitest/vite build imports these, and CI
# has no SpacetimeDB CLI to regenerate them. They change only on a schema edit — regenerate
# with `npm run gen` (spacetime generate) and commit the diff. (M4 reversed the original
# ignore-and-regenerate decision so CI can build the frontend without the spacetime CLI.)

# ── Frontend / bundler ────────────────────────────────
node_modules/
dist/
.vite/
*.tsbuildinfo

# ── Playwright (M5 two-window e2e) output ─────────────
test-results/
playwright-report/
blob-report/
.playwright/

# ── Code knowledge graph index (codebase-memory-mcp) ──
# Derived index — never commit. Confirm the actual dir/config names on first setup
# (the tool writes to agent config + an index dir); add anything it generates here.
.codebase-memory/
.codebase-memory-mcp/
# (kept for reference if you ever switch tools)
.codegraph/
.gitnexus/
.code-graph/

# ── Secrets & env ─────────────────────────────────────
.env
.env.*
!.env.example

# ── SpacetimeDB CLI scratch config ────────────────────
# Auto-generated by the `spacetime` CLI; we pass explicit flags (`-p server-module -s local
# monster-tamer-mmo`) instead, so these are spurious/machine-local. Not used by the project.
spacetime.json
spacetime.local.json

# ── OS / editor ───────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp

# Local Claude Code state (keep shared CLAUDE.md and skills tracked;
# ignore only personal/local settings).
.claude/settings.local.json
# MCP server config contains absolute paths — machine-specific, not shareable.
# Claude Code VS Code extension reads this from the project root (not .claude/).
.mcp.json

# Skills installed via `npx skills add` — derived, reinstall from CLAUDE.md.
.agents/
# npx artifact from `npx skills add` — not a project file.
biome.json
# Root package.json is now a real project file (build-chain scripts + dev tooling) — tracked.
# Its lockfile and node_modules stay ignored (root deps are local dev tooling, not CI-critical).
/package-lock.json